{
	"name": "mdat-plugin-cli-help",
	"version": "1.0.4",
	"description": "Mdat plugin to generate tabular help documentation for CLI tools in Markdown files.",
	"keywords": [
		"markdown",
		"mdat-plugin",
		"mdat",
		"cli",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/mdat-plugin-cli-help",
	"bugs": "https://github.com/kitschpatrol/mdat-plugin-cli-help/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/mdat-plugin-cli-help.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown --no-fixed-extension --tsconfig tsconfig.build.json",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest --no-file-parallelism"
	},
	"dependencies": {
		"@types/which": "^3.0.4",
		"execa": "^9.6.1",
		"read-pkg": "^10.0.0",
		"type-fest": "^5.3.0",
		"which": "^6.0.0"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.10.0",
		"@types/node": "^20.19.25",
		"bumpp": "^10.3.2",
		"chevrotain": "^11.0.3",
		"mdat": "^1.3.2",
		"meow": "^14.0.0",
		"remark-mdat": "^1.2.0",
		"tsdown": "^0.17.0",
		"typescript": "~5.9.3",
		"vitest": "^4.0.15",
		"zod": "^3.25.76"
	},
	"peerDependencies": {
		"mdat": "^1.1.0",
		"remark-mdat": "^1.1.0"
	},
	"packageManager": "pnpm@10.24.0",
	"engines": {
		"node": ">=20.19.0"
	}
}
